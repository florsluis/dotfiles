#!/bin/bash

set -eufo pipefail

{{- if and (eq .profile "work") (has "workSpecific" .features) }}

echo '💼 Installing work-specific tools'
brew bundle --file=/dev/stdin <<EOF
# Taps
tap "atlassian/homebrew-acli"

# Work-specific tools
brew "acli"
brew "jira-cli"
cask "qflipper"
EOF

trap 'exit 0' ERR
echo '✅ Work-specific tools installed!'
{{- else }}
exit 0
{{- end }}